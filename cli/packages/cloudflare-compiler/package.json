  "dependencies": {
    "@x-security/schema": "workspace:*",
    "@x-security/core": "workspace:*",
    "@x-security/shared": "workspace:*",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}

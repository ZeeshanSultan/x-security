{
  "name": "@x-security/core",
  "version": "0.1.0",
  "description": "OpenAPI loader, variable resolver, and normalized IR for x-security generators",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "node --test --import tsx 'test/**/*.test.ts'",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@apidevtools/swagger-parser": "^10.1.1",
    "@x-security/schema": "workspace:*",
    "openapi-types": "^12.1.3",
    "undici": "^6.20.0",
    "yaml": "^2.5.0"
  },
  "devDependencies": {
    "@aws-sdk/client-secrets-manager": "^3.1046.0",
    "@types/node": "^22.0.0",
    "aws-sdk-client-mock": "^4.1.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}

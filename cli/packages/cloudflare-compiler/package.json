{
  "name": "@x-security/cloudflare-compiler",
  "version": "0.1.0",
  "description": "Compile x-security annotations to Cloudflare WAF Custom Rules + Rate Limit + Transform JSON",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": { ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js" } },
  "files": ["dist"],
  "scripts": {

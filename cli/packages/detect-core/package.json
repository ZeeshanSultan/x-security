{
  "name": "@writ/detect-core",
  "version": "0.1.0",
  "description": "Writ deterministic correctness core — LLM-free route extraction, V1–V7 verifiers, cite byte-match, policy compile + canonicalization. The single source of truth for 'is this policy real and valid'.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "pnpm --filter @writ/schema build && tsc -p tsconfig.json",
    "test": "node --test --import tsx 'test/**/*.test.ts'",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@writ/schema": "workspace:*",
    "js-yaml": "^4.1.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}

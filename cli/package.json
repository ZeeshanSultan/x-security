{
  "name": "x-security-cli",
  "private": true,
  "version": "0.1.2",
  "description": "Reference CLI for the x-security OpenAPI extension. Source for the published npm package @chain305/x-security (command: x-security).",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "build": "pnpm --filter @x-security/cli build",
    "test": "pnpm -r --filter=./packages/* test",
    "typecheck": "pnpm -r typecheck",
    "bundle": "pnpm --filter @x-security/cli run bundle:npm -- --name @chain305/x-security --bin x-security"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "esbuild": "^0.24.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
